# Copy this file to backend/.env and fill in the values. .env is gitignored.

# --- AI providers ---
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...

# --- Supabase (service-role key is BACKEND ONLY — never ship to the frontend) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Models (defaults are fine) ---
CHAT_MODEL=claude-haiku-4-5
EMBEDDING_MODEL=voyage-3

# --- Retrieval tuning (defaults are fine) ---
RETRIEVAL_TOP_N=20
RETRIEVAL_TOP_K=5
RRF_K=60

# --- HTTP / CORS + session cookie ---
# Comma-separated exact frontend origins (defaults cover local dev).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Optional regex to allow dynamic origins (e.g. Vercel preview deploys). Leave blank locally.
# Production example: ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app
ALLOWED_ORIGIN_REGEX=
# Session cookie. Local dev = lax/false. Cross-site prod (Vercel <-> Render) = none/true.
COOKIE_SAMESITE=lax
COOKIE_SECURE=false
